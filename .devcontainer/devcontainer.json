{
  "name": "Claude Code Dev Environment",

  // ── Tech stack ───────────────────────────────────────────────
  // Swap the base image to match your project's language/runtime.
  // Popular options:
  //   mcr.microsoft.com/devcontainers/javascript-node:22
  //   mcr.microsoft.com/devcontainers/python:3.12
  //   mcr.microsoft.com/devcontainers/go:1.22
  //   mcr.microsoft.com/devcontainers/rust:1
  //   mcr.microsoft.com/devcontainers/base:ubuntu
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "initializeCommand": "bash .devcontainer/fetch-secrets.sh",
  "runArgs": ["--env-file", ".devcontainer/.env"],
  "postCreateCommand": "sudo chown -R node:node /home/node/.claude && bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/check-auth.sh",

  // ── Persistent Claude Code settings (auth, memory, plugins) ─────────
  // Named volume keeps /home/node/.claude across container rebuilds so
  // you don't need to re-authenticate Claude Code after every rebuild.
  "mounts": [
    "source=ralph-wiggum-claude-home,target=/home/node/.claude,type=volume"
  ],

  // ── Forwarded ports ──────────────────────────────────────────
  // Add ports your app needs (e.g. 3000 for Node, 8000 for Django)
  "forwardPorts": [],

  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
